# ════════════════════════════════════════════════════════════════
# 🛡️ SCAMESCAPE BACKEND - Environment Variables
# ════════════════════════════════════════════════════════════════

# 🌍 Environment & Debug Settings
ENVIRONMENT=development
DEBUG=true
FRONTEND_ORIGIN=http://localhost:3000

# ════════════════════════════════════════════════════════════════
# 🔥 LLM API KEYS - GROQ (REQUIRED)
# ════════════════════════════════════════════════════════════════

# GROQ API Key - Get free from: https://console.groq.com/keys
# Steps: 1) Visit https://console.groq.com/keys
#        2) Sign up with email
#        3) Create new API key
#        4) Copy and paste below
#        ✅ No credit card required | Unlimited free tier
GROQ_API_KEY=gsk_your_groq_api_key_here
GROQ_BASE_URL=https://api.groq.com/openai/v1

# Optional: OpenAI API (not needed - use GROQ instead)
# OPENAI_API_KEY=sk_your_key_here

# Optional: OpenRouter API (not needed - use GROQ instead)
# OPENROUTER_API_KEY=sk_your_key_here

# ════════════════════════════════════════════════════════════════
# 🗄️ DATABASE - MongoDB
# ════════════════════════════════════════════════════════════════

# OPTION A: Local MongoDB (Default)
#   - Install MongoDB Community Edition: https://www.mongodb.com/try/download/community
#   - Default URL: mongodb://localhost:27017
MONGODB_URL=mongodb://localhost:27017

# OPTION B: MongoDB Atlas (Cloud) - Uncomment to use
#   - Sign up: https://www.mongodb.com/cloud/atlas
#   - Create free cluster, get connection string
#   - Format: mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority
# MONGODB_URL=mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority

# Database name
DATABASE_NAME=scamescape

# ════════════════════════════════════════════════════════════════
# 🎮 Game Configuration
# ════════════════════════════════════════════════════════════════

# Game rounds
GAME_ROUNDS=2

# Round duration (seconds)
ROUND_DURATION=300

# Max players per room
MAX_PLAYERS=4

# Difficulty levels (easy, medium, hard)
DEFAULT_DIFFICULTY=medium

# ════════════════════════════════════════════════════════════════
# 🤖 AI & Scam Generator Settings
# ════════════════════════════════════════════════════════════════

# LLM Model for chat generation
LLM_MODEL=llama-3.3-70b-versatile

# Temperature (0.0-2.0) - Higher = more creative/random
# Recommended: 0.95-0.98 for scam variety
LLM_TEMPERATURE=0.97

# Max tokens per response
LLM_MAX_TOKENS=500

# ════════════════════════════════════════════════════════════════
# 📊 Logging & Monitoring
# ════════════════════════════════════════════════════════════════

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log file path (relative to backend directory)
LOG_FILE=backend.log

# ════════════════════════════════════════════════════════════════
# 🔐 Security
# ════════════════════════════════════════════════════════════════

# CORS allowed origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# JWT Secret (change in production!)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# ════════════════════════════════════════════════════════════════
# 🚀 Server Configuration
# ════════════════════════════════════════════════════════════════

# Server host
SERVER_HOST=0.0.0.0

# Server port
SERVER_PORT=8000

# Enable HTTPS (set to true in production)
HTTPS_ENABLED=false

# ════════════════════════════════════════════════════════════════
# 📝 QUICK START INSTRUCTIONS
# ════════════════════════════════════════════════════════════════

# 1️⃣ Copy this file to .env in the backend directory:
#    cp .env.example .env
#
# 2️⃣ Get GROQ API Key (FREE):
#    - Visit: https://console.groq.com/keys
#    - Click "Create API Key"
#    - Copy the key and paste into GROQ_API_KEY above
#
# 3️⃣ Setup Database:
#    LOCAL: Install MongoDB Community Edition from
#           https://www.mongodb.com/try/download/community
#    
#    OR
#    
#    CLOUD: Sign up at https://www.mongodb.com/cloud/atlas (free tier)
#           Create cluster and add connection string to MONGODB_URL
#
# 4️⃣ Start Backend:
#    cd backend
#    python -m uvicorn app.main:app --reload
#
# ✅ Server will start on http://localhost:8000
# ✅ API docs available at http://localhost:8000/docs
